{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(mcp_requests_total{juju_unit=~\"$juju_unit\"}[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(mcp_request_duration_seconds_bucket{juju_unit=~\"$juju_unit\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(mcp_request_duration_seconds_bucket{juju_unit=~\"$juju_unit\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(mcp_request_duration_seconds_bucket{juju_unit=~\"$juju_unit\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Tool Call Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(mcp_tool_calls_total{juju_unit=~\"$juju_unit\"}[5m])) by (tool_name, status)",
          "legendFormat": "{{tool_name}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "mcp_active_connections{juju_unit=~\"$juju_unit\"}",
          "legendFormat": "{{juju_unit}}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(mcp_requests_total{juju_unit=~\"$juju_unit\",status=~\"5..\"}[5m])) / sum(rate(mcp_requests_total{juju_unit=~\"$juju_unit\"}[5m]))",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1}
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["mcp", "juju"],
  "templating": {
    "list": [
      {
        "name": "juju_unit",
        "type": "query",
        "query": "label_values(mcp_requests_total, juju_unit)",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "juju_model",
        "type": "query",
        "query": "label_values(mcp_requests_total, juju_model)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "title": "MCP Server",
  "uid": ""
}
